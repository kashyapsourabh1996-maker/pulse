# =============================================================================
# Pulse — Environment Variables
# Copy this file to `.env` and fill in your values.
# See DEPLOYMENT.md for full setup instructions.
# =============================================================================

# ---- Database ----
# SQLite (simplest — single file, good for small deployments / testing):
DATABASE_URL="file:./db/pulse.db"
#
# PostgreSQL (recommended for production / many users):
#   1. Change `provider = "sqlite"` to `provider = "postgresql"` in prisma/schema.prisma
#   2. Set DATABASE_URL to your Postgres connection string:
# DATABASE_URL="postgresql://user:password@localhost:5432/pulse?schema=public"
#   (Free hosted Postgres: Neon, Supabase, Vercel Postgres, Railway)

# ---- Socket Service (real-time) ----
# The port your socket.io mini-service runs on.
# (Used by the chat-service itself — see mini-services/chat-service/.env.example)
SOCKET_PORT=3003

# ---- Frontend (Next.js public env vars — exposed to the browser) ----
# Controls how the browser connects to the socket service. THREE modes:
#
#   UNSET (don't include this line)  → Sandbox mode (Caddy gateway + XTransformPort)
#   NEXT_PUBLIC_SOCKET_URL=""        → Same-origin production (nginx proxy, path /socket.io)
#   NEXT_PUBLIC_SOCKET_URL="https://socket.yourdomain.com"  → Separate domain (Vercel + Railway)
#
NEXT_PUBLIC_SOCKET_URL=""

# ---- App config ----
# Set to "production" in production. Next.js sets this automatically when built.
# NODE_ENV="production"

# ---- Auth (optional, for future hardening) ----
# If you add JWT/session secrets later, put them here.
# AUTH_SECRET="replace-with-a-long-random-string"
