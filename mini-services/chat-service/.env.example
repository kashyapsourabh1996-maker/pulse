# Socket service environment variables
# Copy to .env in this folder (mini-services/chat-service/) and adjust as needed.

# Port to listen on. SOCKET_PORT takes priority, then PORT (auto-set by Railway/Render), then 3003.
SOCKET_PORT=3003

# Socket.io path. Use "/" for the sandbox Caddy gateway, "/socket.io" for production nginx.
SOCKET_PATH=/

# CORS origin. Set to your frontend URL in production, e.g.:
# SOCKET_CORS_ORIGIN=https://pulse.yourdomain.com
# Use "*" for development.
SOCKET_CORS_ORIGIN=*
